{
  "lesson_number": 5,
  "title": "Lesson 5",
  "topic": "Dative case",
  "grammar": {
    "explanations": [
      "This lesson continues the declension of masculine nouns ending in -a, covering the dative case.",
      "The dative case expresses the meaning 'for' or 'to' in relation to the noun.",
      "The case endings -āya or -ssa are added to the nominal base to form the dative singular.",
      "The case ending -ānaṃ is added to the nominal base to form the dative plural."
    ],
    "tables": [
      {
        "title": "Dative case singular",
        "rows": [
          [
            "nara + āya / ssa",
            "narāya / narassa (for or to the man)"
          ],
          [
            "mātula + āya / ssa",
            "mātulāya / mātulassa (for or to the uncle)"
          ],
          [
            "kassaka + āya / ssa",
            "kassakāya / kassakassa (for or to the farmer)"
          ]
        ]
      },
      {
        "title": "Dative case plural",
        "rows": [
          [
            "nara + ānaṃ",
            "narānaṃ (for or to men)"
          ],
          [
            "mātula + ānaṃ",
            "mātulānaṃ (for or to uncles)"
          ],
          [
            "kassaka + ānaṃ",
            "kassakānaṃ (for or to farmers)"
          ]
        ]
      }
    ],
    "examples": [
      {
        "pali": "Dhīvaro narāya macchaṃ āharati.",
        "english": "The fisherman brings a fish for the man."
      },
      {
        "pali": "Putto mātulassa odanaṃ dadāti.",
        "english": "The son gives rice to the uncle."
      },
      {
        "pali": "Vāṇijo kassakassa ajaṃ dadāti.",
        "english": "The merchant gives a goat to the farmer."
      },
      {
        "pali": "Dhīvarā narānaṃ macche āharanti.",
        "english": "Fishermen bring fish for men."
      },
      {
        "pali": "Puttā mātulānaṃ odanaṃ dadanti.",
        "english": "Sons give rice to uncles."
      },
      {
        "pali": "Vāṇijā kassakānaṃ aje dadanti.",
        "english": "Merchants give goats to farmers."
      }
    ]
  },
