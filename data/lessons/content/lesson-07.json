{
  "lesson_number": 7,
  "title": "Lesson 7",
  "topic": "Locative case",
  "grammar": {
    "explanations": [
      "The locative case is used to express the meanings 'in', 'on', or 'at'.",
      "For masculine nouns ending in -a, the case endings -e, -mhi, or -smiṃ are added to the nominal base to form the locative singular.",
      "The case ending -esu is added to the nominal base to form the locative plural."
    ],
    "tables": [
      {
        "title": "Locative case singular - masculine nouns ending in -a",
        "rows": [
          [
            "nara + e / mhi / smiṃ",
            "nare, naramhi, narasmiṃ (in / on / at the man)"
          ],
          [
            "mātula + e / mhi / smiṃ",
            "mātule, mātulamhi, mātulasmiṃ (in / on / at the uncle)"
          ],
          [
            "kassaka + e / mhi / smiṃ",
            "kassake, kassakamhi, kassakasmiṃ (in / on / at the farmer)"
          ]
        ]
      },
      {
        "title": "Locative case plural - masculine nouns ending in -a",
        "rows": [
          [
            "nara + esu",
            "naresu (in / on / at men)"
          ],
          [
            "mātula + esu",
            "mātulesu (in / on / at uncles)"
          ],
          [
            "kassaka + esu",
            "kassakesu (in / on / at farmers)"
          ]
        ]
      }
    ],
    "examples": [
      {
        "pali": "Sappo narasmiṃ patati.",
        "english": "The snake falls on the man."
      },
      {
        "pali": "Putto mātulamhi pasīdati.",
        "english": "The son is pleased with the uncle."
      },
      {
        "pali": "Vāṇijo kassakasmiṃ pasīdati.",
        "english": "The merchant is pleased with the farmer."
      },
      {
        "pali": "Sappā naresu patanti.",
        "english": "Snakes fall on men."
      },
      {
        "pali": "Puttā mātulesu pasīdanti.",
        "english": "Sons are pleased with their uncles."
      },
      {
        "pali": "Vāṇijā kassakesu pasīdanti.",
        "english": "Merchants are pleased with farmers."
      }
    ]
  },
