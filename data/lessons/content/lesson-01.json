{
  "lesson_number": 1,
  "title": "Lesson 1",
  "topic": "Nominative case, present tense verbs",
  "grammar": {
    "explanations": [
      "Masculine nouns ending in -a form the nominative case singular by adding the case ending -o to the nominal base. They form the nominative case plural by adding the case ending -ā to the nominal base. A noun thus inflected is used as the subject of a sentence.",
      "In the verbs listed, bhāsa, paca, kasa etc. are verbal bases and -ti is the present tense, third person, singular termination. The present tense, third person, plural is formed by adding the termination -nti to the base."
    ],
    "tables": [
      {
        "title": "Nominative case of masculine nouns ending in -a",
        "rows": [
          [
            "Singular",
            "nara + o = naro"
          ],
          [
            "Singular",
            "mātula + o = mātulo"
          ],
          [
            "Singular",
            "kassaka + o = kassako"
          ],
          [
            "Plural",
            "nara + ā = narā"
          ],
          [
            "Plural",
            "mātula + ā = mātulā"
          ],
          [
            "Plural",
            "kassaka + ā = kassakā"
          ]
        ]
      },
      {
        "title": "Present tense, third person verb forms",
        "rows": [
          [
            "Singular",
            "bhāsati - He speaks"
          ],
          [
            "Singular",
            "pacati - He cooks"
          ],
          [
            "Singular",
            "kasati - He ploughs"
          ],
          [
            "Plural",
            "bhāsanti - They speak"
          ],
          [
            "Plural",
            "pacanti - They cook"
          ],
          [
            "Plural",
            "kasanti - They plough"
          ]
        ]
      }
    ],
    "examples": [
