{
  "lesson_number": 4,
  "title": "Lesson 4",
  "topic": "Ablative case",
  "grammar": {
    "explanations": [
      "This lesson continues the declension of masculine nouns ending in -a, focusing on the ablative case.",
      "Case endings -ā, -mhā, or -smā are added to the nominal base to form the ablative singular.",
      "Case ending -ehi is added to the nominal base to form the ablative plural. The ending -ebhi is an archaic form that is also used."
    ],
    "tables": [
      {
        "title": "Ablative case singular",
        "rows": [
          [
            "nara + ā / mhā / smā",
            "narā / naramhā / narasmā (From the man)"
          ],
          [
            "mātula + ā / mhā / smā",
            "mātulā / mātulamhā / mātulasmā (From the uncle)"
          ],
          [
            "kassaka + ā / mhā / smā",
            "kassakā / kassakamhā / kassakasmā (From the farmer)"
          ]
        ]
      },
      {
        "title": "Ablative case plural",
        "rows": [
          [
            "nara + ehi",
            "narehi (narebhi) (From men)"
          ],
          [
            "mātula + ehi",
            "mātulehi (mātulebhi) (From uncles)"
          ],
          [
            "kassaka + ehi",
            "kassakehi (kassakebhi) (From farmers)"
          ]
        ]
      }
    ],
    "examples": [
      {
        "pali": "Yācako naramhā bhattaṃ yācati.",
        "english": "The beggar asks for rice from the man."
      },
      {
        "pali": "Putto mātulamhā pañhaṃ pucchati.",
        "english": "The son asks a question from the uncle."
      },
      {
        "pali": "Kassako rukkhasmā patati.",
        "english": "The farmer falls from the tree."
      },
      {
        "pali": "Yācakā narehi bhattaṃ yācanti.",
        "english": "Beggars ask for rice from men."
      },
      {
        "pali": "Puttā mātulehi pañhe pucchanti.",
        "english": "Sons ask questions from uncles."
      },
      {
        "pali": "Kassakā rukkhehi patanti.",
        "english": "Farmers fall from trees."
      }
    ]
  },
