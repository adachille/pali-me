{
  "lesson_number": 2,
  "title": "Lesson 2",
  "topic": "Accusative case",
  "grammar": {
    "explanations": [
      "Declension of masculine nouns ending in -a (continued): Accusative case.",
      "The case ending -ṃ is added to the nominal base to form the accusative singular number.",
      "The case ending -e is added to the nominal base to form the accusative plural number.",
      "A noun thus inflected is used as the object of a sentence. The goal of motion is also expressed by the accusative case."
    ],
    "tables": [
      {
        "title": "Accusative case - Singular",
        "rows": [
          [
            "nara + ṃ",
            "naraṃ"
          ],
          [
            "mātula + ṃ",
            "mātulaṃ"
          ],
          [
            "kassaka + ṃ",
            "kassakaṃ"
          ]
        ]
      },
      {
        "title": "Accusative case - Plural",
        "rows": [
          [
            "nara + e",
            "nare"
          ],
          [
            "mātula + e",
            "mātule"
          ],
          [
            "kassaka + e",
            "kassake"
          ]
        ]
      }
    ],
    "examples": [
      {
        "pali": "Putto naraṃ passati.",
        "english": "The son sees the man."
      },
      {
        "pali": "Brāhmaṇo mātulaṃ rakkhati.",
        "english": "The brahmin protects the uncle."
      },
      {
        "pali": "Vāṇijo kassakaṃ paharati.",
        "english": "The merchant hits the farmer."
      },
      {
        "pali": "Puttā nare passanti.",
        "english": "Sons see men."
      },
      {
        "pali": "Brāhmaṇā mātule rakkhanti.",
        "english": "Brahmins protect uncles."
      },
      {
        "pali": "Vāṇijā kassake paharanti.",
        "english": "Merchants hit farmers."
      }
    ]
  },
